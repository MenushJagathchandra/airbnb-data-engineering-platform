# Azure Blob Storage Configuration
# Copy this file to .env and fill in your actual values

# Option 1: Connection String (easiest for testing)
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=YOUR_ACCOUNT_NAME;AccountKey=YOUR_ACCOUNT_KEY;EndpointSuffix=core.windows.net

# Option 2: Service Principal (for production)
# AZURE_STORAGE_ACCOUNT_URL=https://YOUR_ACCOUNT_NAME.blob.core.windows.net
# AZURE_TENANT_ID=your-tenant-id
# AZURE_CLIENT_ID=your-client-id
# AZURE_CLIENT_SECRET=your-client-secret

# Option 3: Managed Identity (when running on Azure VM/AKS)
# AZURE_STORAGE_ACCOUNT_URL=https://YOUR_ACCOUNT_NAME.blob.core.windows.net